{
  "name": "chess-reviewer",
  "version": "1.0.0",
  "description": "Local Chess Reviewer and Analysis Tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.6.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.chessreviewer.app",
    "productName": "ChessReviewer",
    "win": {
      "target": [
        "portable"
      ]
    },
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/backend_server.exe",
        "to": "backend_server.exe"
      },
      {
        "from": "config.json",
        "to": "config.json"
      }
    ]
  }
}
